<nav id="navbar"
     class="fixed top-0 left-0 w-full bg-transparent shadow-none z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 flex justify-between items-center h-16">
    <!-- Logo -->
   <a href="/" id="logo"
   class="font-serif text-xl font-bold 
          text-[#28343D]
          [text-shadow:_-1px_-1px_0_white,_1px_-1px_0_white,_-1px_1px_0_white,_1px_1px_0_white]">
  Alma S.R.L
</a>

    <!-- Botón hamburguesa (solo móvil) -->
    <button id="menu-btn" class="md:hidden text-3xl text-[#white] focus:outline-none">
      ☰
    </button>

    <!-- Menú escritorio -->
    <div id="menu" class="hidden md:flex space-x-6">
      <a href="/" class="hover:underline text-gray-100">Inicio</a>
      <a href="/Servicios" class="hover:underline text-gray-100">Servicios</a>
      <a href="/Alquiler" class="hover:underline text-gray-100">Alquileres</a>
      <a href="/Nosotros" class="hover:underline text-gray-100">Quiénes Somos</a>
      <a href="/contact" class="hover:underline text-gray-100">Contactanos</a>
      
    </div>
  </div>

  <!-- Panel lateral móvil -->
  <div id="mobile-panel"
       class="fixed top-0 right-0 h-screen w-72 bg-[#28343D] transform translate-x-full transition-transform duration-300 ease-in-out md:hidden z-50 p-8">
      <div class="flex flex-col gap-4 mt-12">
        <a href="/" class="text-lg text-white hover:underline py-2 border-b border-white/20">Inicio</a>
        <a href="/Servicios" class="text-lg text-white hover:underline py-2 border-b border-white/20">Servicios</a>
        <a href="/Alquiler" class="text-lg text-white hover:underline py-2 border-b border-white/20">Alquileres</a>
        <a href="/Nosotros" class="text-lg text-white hover:underline py-2 border-b border-white/20">Quiénes Somos</a>
        <a href="/contact" class="text-lg text-white hover:underline py-2 border-b border-white/20">Contactanos</a>
      </div>
  </div>

  <!-- Overlay oscuro (más opacidad para mayor contraste) -->
  <div id="overlay"
       class="fixed inset-0 bg-black bg-opacity-90 hidden md:hidden z-40"></div>
</nav>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const navbar      = document.querySelector("#navbar");
  const hero        = document.querySelector("#main");
  const btn         = document.querySelector("#menu-btn");
  const mobilePanel = document.querySelector("#mobile-panel");
  const overlay     = document.querySelector("#overlay");

  function closeMenu() {
    mobilePanel.classList.add("translate-x-full");
    overlay.classList.add("hidden");
  }

  // --- Menú lateral móvil ---
  btn?.addEventListener("click", () => {
    mobilePanel.classList.remove("translate-x-full");
    overlay.classList.remove("hidden");
  });

  // Cerrar tocando cualquier lugar fuera del panel
  document.addEventListener("click", (e) => {
    if (
      !mobilePanel.contains(e.target) &&   // click fuera del panel
      !btn.contains(e.target) &&           // no en el botón hamburguesa
      !mobilePanel.classList.contains("translate-x-full")
    ) {
      closeMenu();
    }
  });

  // --- Cambio de navbar al hacer scroll ---
  function updateNavbar() {
    if (!navbar) return;
    const trigger = hero ? hero.offsetHeight : 50;

    if (window.scrollY >= trigger) {
      navbar.classList.remove("bg-transparent", "shadow-none");
      navbar.classList.add("bg-gray", "shadow-lg");
      navbar.querySelectorAll("a").forEach(a => {
        if (!a.classList.contains("bg-trasparent")) {
          a.classList.remove("text-[#28343D]");
          a.classList.add("text-black");
        }
      });
    } else {
      navbar.classList.remove("bg-white", "shadow-lg");
      navbar.classList.add("bg-transparent", "shadow-none");
      navbar.querySelectorAll("a").forEach(a => {
        if (!a.classList.contains("bg-black")) {
          a.classList.remove("text-black");
          a.classList.add("text-[#28343D]");
        }
      });
    }
  }

  window.addEventListener("scroll", updateNavbar);
  window.addEventListener("resize", updateNavbar);
  updateNavbar();
});
</script>


