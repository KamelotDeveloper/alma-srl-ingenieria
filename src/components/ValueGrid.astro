---
import Carru3 from "./Carru3.astro";
import Contador from "./Contador.astro";
import Galeria from "./Galeria.astro";
import Intro from "./Intro.astro";
---

<section class="px-6 py-16 max-w-6xl mx-auto reveal">
  <header class="text-center mb-10">
    <h2 class="font-serif text-3xl text-gray-100">Áreas principales</h2>
    <p class="mt-2 text-gray-300/90 max-w-2xl mx-auto">
      Elegí lo que necesitás y entrá directo a la sección correspondiente.
    </p>
  </header>

  <div class="grid gap-6 md:grid-cols-3">
    <!-- SERVICIOS -->
    <a
      href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/Servicios'}
      class="group rounded-2xl border border-white/10 bg-white/5 p-5
             hover:bg-white/10 hover:border-white/20 transition
             focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
      aria-label="Ir a Servicios"
    >
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 class="text-xl font-semibold text-gray-100">Servicios</h3>
          <p class="mt-1 text-sm text-gray-300">
            Ingeniería, dirección de obra, cálculos y proyectos.
          </p>
        </div>
        <span class="text-gray-300 group-hover:text-white transition" aria-hidden="true">→</span>
      </div>

      <div class="mt-4 overflow-hidden rounded-xl border border-white/10 bg-slate-950/25">
        <Intro />
      </div>

      <div class="mt-4 inline-flex items-center text-sm font-semibold text-gray-100">
        Ver servicios <span class="ml-2 group-hover:translate-x-1 transition" aria-hidden="true">→</span>
      </div>
    </a>

    <!-- ALQUILER -->
    <a
      href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/Alquiler'}
      class="group rounded-2xl border border-white/10 bg-white/5 p-5
             hover:bg-white/10 hover:border-white/20 transition
             focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
      aria-label="Ir a Alquiler de herramientas"
    >
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 class="text-xl font-semibold text-gray-100">Alquiler</h3>
          <p class="mt-1 text-sm text-gray-300">
            Herramientas y equipos para obra y mantenimiento.
          </p>
        </div>
        <span class="text-gray-300 group-hover:text-white transition" aria-hidden="true">→</span>
      </div>

      <div class="mt-4 overflow-hidden rounded-xl border border-white/10 bg-slate-950/25">
        <Galeria />
      </div>

      <div class="mt-4 inline-flex items-center text-sm font-semibold text-gray-100">
        Ver alquiler <span class="ml-2 group-hover:translate-x-1 transition" aria-hidden="true">→</span>
      </div>
    </a>

    <!-- TIENDA -->
    <a
      href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/Tienda'}
      class="group rounded-2xl border border-white/10 bg-white/5 p-5
             hover:bg-white/10 hover:border-white/20 transition
             focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
      aria-label="Ir a Tienda"
    >
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 class="text-xl font-semibold text-gray-100">Tienda</h3>
          <p class="mt-1 text-sm text-gray-300">
            Pinturería, productos y soluciones para tu obra.
          </p>
        </div>
        <span class="text-gray-300 group-hover:text-white transition" aria-hidden="true">→</span>
      </div>

      <div class="mt-4 overflow-hidden rounded-xl border border-white/10 bg-slate-950/25">
        <Carru3 />
      </div>

      <div class="mt-4 inline-flex items-center text-sm font-semibold text-gray-100">
        Ver tienda <span class="ml-2 group-hover:translate-x-1 transition" aria-hidden="true">→</span>
      </div>
    </a>
  </div>

  <!-- TRABAJOS Y CLIENTES -->
  <section class="mt-14 reveal">
    <header class="text-center mb-8">
      <h2 class="font-serif text-3xl text-gray-100">Trabajos y clientes</h2>
      <p class="mt-2 text-gray-300/90 max-w-2xl mx-auto">
        Experiencia, volumen y confianza respaldada por resultados.
      </p>
    </header>
    <Contador />
  </section>

  <style>
    /* Reveal simple y consistente (un solo sistema) */
    .reveal {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 700ms ease, transform 700ms ease;
      will-change: opacity, transform;
    }
    .reveal.show {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    const targets = document.querySelectorAll(".reveal");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduceMotion) {
      targets.forEach((el) => el.classList.add("show"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("show");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.18 }
      );

      targets.forEach((el) => io.observe(el));
    }
  </script>
</section>

