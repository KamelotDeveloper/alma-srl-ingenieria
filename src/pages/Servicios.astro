---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

// Datos (mejor mantenible que hardcodear <li>)
const CATEGORIES = [
  {
    title: "Ingeniería & Proyectos",
    desc: "Documentación técnica, cálculo y planificación para ejecutar con seguridad y control de costos.",
    items: [
      { title: "Cálculo estructural", subtitle: "Dimensionamiento y verificación de estructuras." },
      { title: "Modelado BIM", subtitle: "Coordinación y detección de interferencias." },
      { title: "Estimación de costos", subtitle: "Cómputos, presupuestos y métricas." },
      { title: "Legalizaciones y trámites técnicos", subtitle: "Gestión y presentación técnica." },
      { title: "Diseño de instalaciones sanitarias", subtitle: "Planos y especificaciones." },
      { title: "Diseño de redes cloacales y acueductos", subtitle: "Proyecto integral de redes." },
    ],
  },
  {
    title: "Obras & Construcción",
    desc: "Ejecución y dirección para obras residenciales, comerciales e industriales.",
    items: [
      { title: "Dirección y ejecución de obras", subtitle: "Planificación, control y seguimiento." },
      { title: "Desarrollos urbanos", subtitle: "Loteos, infraestructura y urbanización." },
      { title: "Construcciones metálicas", subtitle: "Estructuras, refuerzos y montaje." },
      { title: "Remodelaciones", subtitle: "Reacondicionamiento y mejoras integrales." },
    ],
  },
  {
    title: "Pinturería & Protección",
    desc: "Soluciones técnicas para protección, mantenimiento y terminaciones.",
    items: [
      { title: "Impermeabilización de techos y cubiertas", subtitle: "Sistemas y aplicación profesional." },
      { title: "Pintura arquitectónica e industrial", subtitle: "Terminaciones, mantenimiento y performance." },
      { title: "Distribuidores oficiales de SIKA Argentina", subtitle: "Productos y asesoramiento técnico." },
    ],
  },
  {
    title: "Alquiler & Servicios",
    desc: "Equipos y soporte técnico para facilitar la ejecución en obra.",
    items: [
      { title: "Alquiler de herramientas", subtitle: "Equipos para obra y mantenimiento." },
      { title: "Ingeniería mecánica", subtitle: "Soluciones técnicas y soporte especializado." },
    ],
  },
];

// Íconos simples (SVG inline) sin depender de librerías
const ICONS = {
  "Ingeniería & Proyectos": `<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
    <path d="M4 19h16M6 17V7l6-3 6 3v10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M9 17v-6m6 6v-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
  </svg>`,
  "Obras & Construcción": `<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
    <path d="M3 21h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M7 21V9l5-3 5 3v12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M10 21v-5h4v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  "Pinturería & Protección": `<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
    <path d="M4 12c3-6 13-6 16 0-3 6-13 6-16 0Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    <path d="M12 16v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M10 20h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
  </svg>`,
  "Alquiler & Servicios": `<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
    <path d="M7 21h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M9 21V7a3 3 0 0 1 6 0v14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M6 11h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
  </svg>`,
};
---

<Base>
  <Nav />

  <main class="px-6 pt-24 md:pt-28 max-w-6xl mx-auto fade-in-left">
    <!-- HERO -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
      <!-- Texto -->
      <div class="md:col-span-6">
        <p class="text-sm tracking-wide uppercase text-white/60 mb-3">
          Servicios integrales
        </p>

        <h1 class="font-serif text-4xl md:text-5xl leading-tight">
          Ingeniería, obra y soluciones técnicas con criterio profesional
        </h1>

        <p class="mt-4 text-white/75 leading-relaxed max-w-prose">
          Te acompañamos desde el proyecto hasta la ejecución, con foco en calidad, plazos y control de costos.
          Elegí una categoría y pedí presupuesto en minutos.
        </p>

        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a
            href="/contactanos"
            class="inline-flex items-center justify-center rounded-xl px-5 py-3 font-semibold
                   bg-white text-slate-900 hover:bg-white/90 transition shadow"
          >
            Solicitar presupuesto
          </a>

          <a
            href="#servicios"
            class="inline-flex items-center justify-center rounded-xl px-5 py-3 font-semibold
                   border border-white/20 text-white hover:bg-white/10 transition"
          >
            Ver servicios
          </a>
        </div>

        <div class="mt-6 flex flex-wrap gap-2 text-xs text-white/60">
          <span class="rounded-full border border-white/10 px-3 py-1">Asesoramiento técnico</span>
          <span class="rounded-full border border-white/10 px-3 py-1">Presupuesto y cómputo</span>
          <span class="rounded-full border border-white/10 px-3 py-1">Ejecución y seguimiento</span>
        </div>
      </div>

      <!-- Imagen -->
      <div class="md:col-span-6">
        <div class="relative overflow-hidden rounded-2xl border border-white/10 shadow-lg">
          <img
            src="/images/servicios-hero.jpg"
            alt="Proyecto y ejecución de obras"
            class="w-full h-[260px] md:h-[380px] object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-slate-950/10 to-transparent"></div>

          <div class="absolute bottom-4 left-4 right-4">
            <div class="rounded-xl bg-slate-950/50 backdrop-blur border border-white/10 px-4 py-3">
              <p class="text-sm font-semibold">Respuesta rápida</p>
              <p class="text-xs text-white/70">
                Contanos tu necesidad y te armamos una propuesta técnica.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="mt-14 md:mt-16">
      <div class="flex items-end justify-between gap-6 mb-6">
        <div>
          <h2 class="font-serif text-3xl md:text-4xl">Nuestros Servicios</h2>
          <p class="text-white/70 mt-2 max-w-2xl">
            Organizamos los servicios por categorías para que encuentres rápido lo que necesitás.
          </p>
        </div>

        <a
          href="/contactanos"
          class="hidden md:inline-flex items-center justify-center rounded-xl px-4 py-2 font-semibold
                 border border-white/15 text-white hover:bg-white/10 transition"
        >
          Contactar
        </a>
      </div>

      <div class="space-y-10">
        {CATEGORIES.map((cat) => (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-5 md:p-6">
            <header class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
              <div class="flex items-start gap-3">
                <div class="mt-1 text-white/80" set:html={ICONS[cat.title] ?? ""} />
                <div>
                  <h3 class="text-xl md:text-2xl font-semibold">{cat.title}</h3>
                  <p class="text-white/70 mt-1 max-w-2xl">{cat.desc}</p>
                </div>
              </div>

              <a
                href="/contactanos"
                class="inline-flex items-center justify-center rounded-xl px-4 py-2 font-semibold
                       bg-white text-slate-900 hover:bg-white/90 transition"
              >
                Pedir presupuesto
              </a>
            </header>

            <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {cat.items.map((it) => (
                <article
                  class="rounded-xl border border-white/10 bg-slate-950/30 p-4
                         hover:bg-slate-950/45 hover:border-white/20 transition"
                >
                  <p class="font-semibold">{it.title}</p>
                  <p class="text-sm text-white/70 mt-1">{it.subtitle}</p>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- CTA final -->
      <div class="mt-10 mb-24 rounded-2xl border border-white/10 bg-white/5 p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h3 class="text-xl font-semibold">¿Querés que lo evaluemos hoy?</h3>
          <p class="text-white/70 mt-1">
            Enviá tu consulta y te respondemos con propuesta técnica y próximos pasos.
          </p>
        </div>
        <a
          href="/contactanos"
          class="inline-flex items-center justify-center rounded-xl px-5 py-3 font-semibold
                 bg-white text-slate-900 hover:bg-white/90 transition shadow"
        >
          Ir a Contacto
        </a>
      </div>
    </section>

    <style>
      @keyframes fadeInLeft {
        0% { opacity: 0; transform: translateX(-20px); }
        100% { opacity: 1; transform: translateX(0); }
      }
      .fade-in-left { animation: fadeInLeft 1.1s ease-out forwards; }
    </style>
  </main>

  <Footer />
</Base>
