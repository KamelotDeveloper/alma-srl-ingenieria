---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const WA_NUMBER = "5493571594446";
const WA_TEXT = encodeURIComponent(
  "Hola, quiero consultar por alquiler de herramientas. ¿Qué tienen disponible?"
);
const WHATSAPP_URL = `https://wa.me/${WA_NUMBER}?text=${WA_TEXT}`;

const tools = [
{
name: "Autoelevador triple torre 2,5 toneladas",
short: "Equipo para elevación y movimiento de cargas.",
image: "https://almatec.com.ar/wp-content/uploads/2024/06/EFX.png"
},
{
name: "Martillo demoledor eléctrico",
short: "Herramienta para demolición de hormigón.",
image: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRY_X7RANPfKw5AdJoI0tjVDGBDmUL9oDsCsw&s"
},
{
name: "Generador de electricidad",
short: "Generador portátil para suministro eléctrico.",
image: "https://philco.com.ar/media/wysiwyg/generador.PNG"
},
{
name: "Andamios tubulares",
short: "Estructura para trabajos en altura.",
image: "https://http2.mlstatic.com/D_NQ_NP_750259-MLA95069524336_102025-O.webp"
},
{
name: "Amoladora angular",
short: "Herramienta para corte y desbaste.",
image: "data:image/jpeg;base64,"
},
{
name: "Taladro eléctrico",
short: "Perforación en madera, metal o mampostería.",
image: "data:image/jpeg;base64,"
},
{
name: "Guinche plegable hidráulico 2 toneladas",
short: "Equipo para levantar motores o cargas.",
image: "data:image/jpeg;base64,"
},
{
name: "Nivel láser",
short: "Nivelación precisa para obra.",
image: "data:image/jpeg;base64,"
},
{
name: "Nivel óptico",
short: "Instrumento profesional de medición.",
image: "https://marferherramientas.com/wp-content/uploads/2020/07/bosch16.jpg"
},
{
name: "Máquina de soldar trifásica ESAB",
short: "Equipo profesional de soldadura.",
image: "data:image/jpeg;base64,"
},
{
name: "Máquina de soldar monofásica",
short: "Soldadora compacta para trabajos generales.",
image: "data:image/jpeg;base64,"
}
];
---

<Base>
<Nav />

<main class="px-6 pt-24 md:pt-28 max-w-6xl mx-auto">

<header class="text-center mb-10">
<p class="text-sm uppercase tracking-wide text-white/60">Alquiler</p>
<h1 class="font-serif text-4xl md:text-5xl mt-2">Herramientas para tu obra</h1>

<p class="mt-3 text-white/75 max-w-2xl mx-auto">
Equipos disponibles para alquiler según disponibilidad.
Consultanos para coordinar.
</p>

<div class="mt-6 flex justify-center">
<a
href={WHATSAPP_URL}
target="_blank"
rel="noopener noreferrer"
class="inline-flex items-center justify-center rounded-xl px-6 py-3 font-semibold bg-white text-slate-900 hover:bg-white/90 transition"
>
Consultar por WhatsApp
</a>
</div>
</header>

<section class="rounded-2xl border border-white/10 bg-white/5 p-6">

<div class="flex flex-col md:flex-row gap-4 md:items-center md:justify-between">

<div>
<h2 class="font-serif text-2xl">Catálogo</h2>
<p class="text-white/70 mt-1">
Herramientas disponibles para alquiler.
</p>
</div>

<input
id="toolSearch"
type="text"
placeholder="Buscar herramienta..."
class="w-full md:w-80 rounded-xl bg-slate-950/40 border border-white/10 px-4 py-3 text-white placeholder:text-white/40"
/>

</div>

<div
id="toolGrid"
class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
>

{tools.map((tool) => (

<article
class="tool-card rounded-2xl border border-white/10 bg-slate-950/25 overflow-hidden hover:border-white/20 transition"
data-name={tool.name.toLowerCase()}
>

<img
src={tool.image}
alt={tool.name}
 class="w-full h-44 object-contain rounded-lg mb-4 bg-white p-2"
/>

<div class="p-5">

<h3 class="text-xl font-semibold text-white">
{tool.name}
</h3>

<p class="mt-2 text-sm text-white/70">
{tool.short}
</p>

<a
href={WHATSAPP_URL}
target="_blank"
rel="noopener noreferrer"
class="mt-5 inline-flex w-full items-center justify-center rounded-xl px-4 py-3 font-semibold bg-white text-slate-900 hover:bg-white/90 transition"
>
Consultar disponibilidad
</a>

</div>

</article>

))}

</div>

</section>

</main>

<script>

const input = document.getElementById("toolSearch");
const cards = document.querySelectorAll(".tool-card");

if (input) {

input.addEventListener("input", (e) => {

const q = e.target.value.toLowerCase();

cards.forEach((card) => {

const name = card.dataset.name || "";

card.style.display = name.includes(q) ? "" : "none";

});

});

}

</script>

<!-- COMO ALQUILAR --> <section class="max-w-6xl mx-auto px-6 py-20 border-t border-white/10"> <h2 class="text-3xl font-bold text-white text-center mb-12"> Cómo alquilar </h2> <div class="grid md:grid-cols-3 gap-8 text-center"> <div> <h3 class="text-xl font-semibold text-white mb-3"> 1. Consultá disponibilidad </h3> <p class="text-white/70"> Escribinos por WhatsApp indicando la herramienta que necesitás y la fecha. </p> </div> <div> <h3 class="text-xl font-semibold text-white mb-3"> 2. Coordinamos el alquiler </h3> <p class="text-white/70"> Confirmamos disponibilidad, precio y tiempo de alquiler del equipo. </p> </div> <div> <h3 class="text-xl font-semibold text-white mb-3"> 3. Retirá o recibí el equipo </h3> <p class="text-white/70"> Podés retirarlo en el local o coordinar entrega según disponibilidad. </p> </div> </div> </section>
 

<Footer />
</Base>