---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Formulario from "../components/Formulario.astro";

const EMAIL = "ing.marinmelina@gmail.com";
const PHONE_1 = "3571-594446";
const PHONE_2 = "3571-594447";

// WhatsApp: usar número con código país sin + en la URL
const WA_NUMBER = "5493571594446";
const WA_TEXT = encodeURIComponent("Hola, quiero consultar por un presupuesto. ¿Me ayudan?");
---

<Base>
  <Nav />

  <main class="px-6 pt-24 md:pt-28 max-w-6xl mx-auto">
    <!-- HERO CONTACTO -->
    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-wide text-white/60">Contacto</p>
      <h1 class="font-serif text-4xl md:text-5xl mt-2">Hablemos sobre tu proyecto</h1>
      <p class="mt-3 text-white/75 max-w-2xl mx-auto leading-relaxed">
        Contanos qué necesitás y te respondemos con próximos pasos y una propuesta técnica.
      </p>

      <!-- Acciones rápidas -->
      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={`https://wa.me/+543571594446`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-xl px-6 py-3 font-semibold
                 bg-white text-slate-900 hover:bg-white/90 transition shadow"
        >
          Escribir por WhatsApp
        </a>

        <a
          href={`#email`}
          class="inline-flex items-center justify-center rounded-xl px-6 py-3 font-semibold
                 border border-white/20 text-white hover:bg-white/10 transition"
        >
          Enviar email
        </a>
      </div>
    </header>

    <!-- FORM -->
    <section class="rounded-2xl border border-white/10 bg-white/5 p-5 md:p-6">
      <Formulario />
      <p class="mt-4 text-sm text-white/60">
        Al enviar, aceptás que te contactemos para responder tu consulta.
      </p>
    </section>

    <!-- DATOS DIRECTOS -->
    <section id="email" class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <h2 class="font-serif text-2xl">Datos de contacto</h2>

        <div class="mt-4 space-y-3 text-white/80">
          <p>
            <span class="text-white/60">E-mail:</span>{" "}
            <ul>
              <li>info@almaingenieria.com.ar</li>
              <li>ventas@almaingenieria.com.ar</li>
              <li>contacto@almaingenieria.com.ar</li>
              <li>proyectos@almaingenieria.com.ar</li>
              <li>administracion@almaingenieria.com.ar</li>
            </ul>
          </p>

          <p class="space-y-1">
            <span class="text-white/60 block">Teléfono:</span>
            <a class="underline hover:text-white block" href={`https://wa.me/+543571594446`}> 3571-594446</a>
          </p>
        </div>

        <a
          class="mt-5 inline-flex items-center justify-center rounded-xl px-5 py-3 font-semibold
                 border border-white/20 text-white hover:bg-white/10 transition w-full sm:w-auto"
          href={`https://wa.me/+543571594446`}
          target="_blank"
          rel="noopener noreferrer"
        >
          Abrir WhatsApp
        </a>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <h2 class="font-serif text-2xl">Redes</h2>
        <p class="mt-2 text-white/70">
          Mirá trabajos, novedades y productos.
        </p>

        <div class="mt-5 flex gap-6">
          <!-- Instagram -->
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.instagram.com/pinturerias_almacolor/"
            class="hover:scale-110 transition-transform"
            aria-label="Instagram"
            title="Instagram"
          >
            <span class="inline-block w-10 h-10">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" width="100%" height="100%" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="white" stroke-width="1.6" fill="none"/>
                <circle cx="12" cy="11.5" r="3" stroke="white" stroke-width="1.6" fill="none"/>
                <circle cx="17.2" cy="6.8" r="0.9" fill="white"/>
              </svg>
            </span>
          </a>

          <!-- Facebook (poner URL real) -->
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.facebook.com/"
            class="hover:scale-110 transition-transform"
            aria-label="Facebook"
            title="Facebook"
          >
            <span class="inline-block w-10 h-10">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="100%" height="100%" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="4" ry="4" stroke="white" stroke-width="1.6" fill="none"/>
                <path d="M15.5 3H13c-2.76 0-4 1.79-4 4v2H6v3h3v7h3v-7h2.21l.79-3H12V7.2c0-.86.4-1.2 1.28-1.2H16V3z" fill="white"/>
              </svg>
            </span>
          </a>
        </div>

        <p class="mt-6 text-sm text-white/60">
           agregá un link a Google Maps si recibís gente en oficina/local.
        </p>
      </div>
    </section>

    <div class="h-16"></div>
  </main>

  <Footer />
</Base>
